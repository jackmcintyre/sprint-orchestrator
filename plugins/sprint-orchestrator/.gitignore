# Orchestrator runtime state. The canonical state file lives outside
# git so per-story branches cannot fork the state machine. See story 1
# of the orchestrator-state-and-shipgate sprint.
.sprint-orchestrator/state.*
.sprint-orchestrator/run.log
.sprint-orchestrator/*.lock

# Build / install output that ships with the plugin packages but should
# never land in commits.
**/node_modules/
**/dist/
**/coverage/
